+static def versionNumberParts(version) {
+  def matcher = (version =~ /(\d+)\.(\d+)(?:\.(\d+))?/)
+  if (!matcher.find()) {
+    return [0, 0, 0]
+  }
+  return [
+    matcher.group(1).toInteger(),
+    matcher.group(2).toInteger(),
+    matcher.group(3) ? matcher.group(3).toInteger() : 0
+  ]
+}
+
+static def isVersionLessThan(version, target) {
+  def left = versionNumberParts(version)
+  def right = versionNumberParts(target)
+  for (int index = 0; index < 3; index++) {
+    if (left[index] != right[index]) {
+      return left[index] < right[index]
+    }
+  }
+  return false
+}
