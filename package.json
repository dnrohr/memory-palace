{
  "name": "memory-palace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "apps/mobile/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "start": "expo start",
    "web": "expo start --web",
    "verify": "npm run build && npm test && npx expo config --type public",
    "android": "expo run:android",
    "pixel8:build": "node scripts/pixel8-run-android.mjs",
    "pixel8": "expo start --dev-client --android",
    "pixel8:tunnel": "expo start --dev-client --tunnel",
    "pixel8:install-standalone": "node scripts/pixel8-install-standalone.mjs",
    "pixel8:preflight": "node scripts/pixel8-preflight.mjs",
    "ios": "expo run:ios",
    "postinstall": "patch-package",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@expo/metro-runtime": "^56.0.15",
    "@huggingface/transformers": "^4.2.0",
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^56.0.11",
    "expo-dev-client": "~56.0.20",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-local-authentication": "~56.0.4",
    "expo-secure-store": "~56.0.4",
    "expo-speech-recognition": "^56.0.1",
    "expo-splash-screen": "~56.0.10",
    "expo-sqlite": "^56.0.5",
    "llama.rn": "^0.12.4",
    "lucide-react-native": "^1.17.0",
    "onnxruntime-react-native": "^1.24.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2"
  }
}
